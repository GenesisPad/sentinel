NODE_ENV=development
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=4000
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_TIME_WINDOW=1 minute
API_CORS_ORIGIN=http://localhost:3000
# Required to issue admin-created partner API keys with custom scopes or limits.
API_ADMIN_SECRET=
WORKER_CONCURRENCY=2
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Same web app URL, read by the API/Telegram bot to build "Full Report" links back to it.
WEB_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/genesis_sentinel
REDIS_URL=redis://localhost:6379
ROBINHOOD_RPC_URL=
ROBINHOOD_FALLBACK_RPC_URLS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated Telegram user IDs allowed to access /stats and /charts.
TELEGRAM_ADMIN_IDS=
TELEGRAM_SCAN_COOLDOWN_SECONDS=15
TELEGRAM_SCAN_BURST_LIMIT=5
TELEGRAM_SCAN_BURST_WINDOW_SECONDS=300
SIMULATION_FORK_ENABLED=false
SIMULATION_FORK_TIMEOUT_MS=30000
SIMULATION_FORK_NATIVE_AMOUNT_WEI=1000000000000000
SENTRY_DSN=
